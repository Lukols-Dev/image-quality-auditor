
# ============================================================
# NeuroFace Image Quality Auditor — Configuration
# ============================================================
#
# Copy this file to .env and adjust values as needed:
#   cp .env.example .env
#
# All variables are OPTIONAL. When unset, the defaults shown
# below (from config.py) are used. Uncomment and modify only
# the values you want to override.
#
# Priority: environment variable > .env file > code default
# ============================================================

# ------------------------------------------------------------
# Quality thresholds (drive image classification)
# ------------------------------------------------------------

# Mean brightness below this = underexposed (too dark)
# Range: 0.0-255.0 | Default: 30.0
# NEUROFACE_MIN_BRIGHTNESS=30.0

# Mean brightness above this = overexposed (too bright)
# Range: 0.0-255.0 | Default: 225.0
# NEUROFACE_MAX_BRIGHTNESS=225.0

# Contrast (pixel std dev) below this = too flat
# Range: >= 0.0 | Default: 20.0
# NEUROFACE_MIN_CONTRAST=20.0

# Sharpness (Laplacian variance) below this = too blurry
# Range: >= 0.0 | Default: 100.0
# NEUROFACE_MIN_SHARPNESS=100.0

# ------------------------------------------------------------
# Size requirements
# ------------------------------------------------------------

# Minimum acceptable image width in pixels
# Range: > 0 | Default: 640
# NEUROFACE_MIN_WIDTH=640

# Minimum acceptable image height in pixels
# Range: > 0 | Default: 480
# NEUROFACE_MIN_HEIGHT=480

# Maximum file size in MB (guards against decompression bombs)
# Range: > 0.0 | Default: 50.0
# NEUROFACE_MAX_FILE_SIZE_MB=50.0

# ------------------------------------------------------------
# Output settings
# ------------------------------------------------------------

# Directory where reports (CSV, HTML) are written
# Default: ./output
# NEUROFACE_OUTPUT_DIR=./output

# ------------------------------------------------------------
# Operational settings
# ------------------------------------------------------------

# Logging level: DEBUG, INFO, WARNING, ERROR, CRITICAL
# Default: INFO
# NEUROFACE_LOG_LEVEL=INFO
